-- extração no MySQL para listings_calendar (Q3, Q5, Q6 e Q9)
SELECT
    YEAR(c.date) AS year,
    MONTH(c.date) AS month,
    l.neighbourhood,
    l.room_type,
    c.listing_id,
    c.date,
    CASE
        WHEN c.available = 1 THEN 'true'
        WHEN c.available = 0 THEN 'false'
        ELSE NULL
    END AS available,
    l.price,
    l.minimum_nights
FROM Calendar c
JOIN Listings l
ON c.listing_id = l.id;


-- extração no MySQL para listings_by_neighbourhood (Q1 e Q2)
SELECT 
    l.neighbourhood,
    l.room_type,
    l.id AS listing_id,
    l.price,
    l.review_scores_rating,
    l.number_of_reviews
FROM Listings l;


-- extração no MySQL para listings_features_calendar (Q8)
SELECT 
    YEAR(c.date) AS year,
    MONTH(c.date) AS month,
    l.accommodates,
    l.room_type,
    l.neighbourhood,
    c.listing_id,
    c.date,
    CASE
        WHEN c.available = 1 THEN 'true'
        WHEN c.available = 0 THEN 'false'
        ELSE NULL
    END AS available,
    l.price
FROM Calendar c
JOIN Listings l ON c.listing_id = l.id;


-- extração no MySQL para hosts_summary (Q4)
SELECT
    h.host_id,
    h.host_name,
    h.host_is_superhost AS superhost,
    COUNT(DISTINCT l.id) AS total_casas,
    COUNT(r.id) AS total_avaliacoes
FROM Hosts h
LEFT JOIN Listings l
    ON h.host_id = l.host_id
LEFT JOIN Reviews r
    ON l.id = r.listing_id
GROUP BY
    h.host_id,
    h.host_name,
    h.host_is_superhost
ORDER BY
    total_casas DESC;


-- extração no MySQL para listings_reviews_reservas (Q7 e 10)
SELECT
    r.reviewer_id,
    r.reviewer_name,
    r.listing_id,
    l.room_type,
    l.neighbourhood,
    rr.total_reviews_reviewer,
    rl.total_reviews_listing,
    c.total_reservas_listing
FROM Reviews r
JOIN Listings l ON r.listing_id = l.id
LEFT JOIN (
    SELECT reviewer_id, COUNT(*) AS total_reviews_reviewer
    FROM Reviews
    GROUP BY reviewer_id
) rr ON rr.reviewer_id = r.reviewer_id
LEFT JOIN (
    SELECT listing_id, COUNT(*) AS total_reviews_listing
    FROM Reviews
    GROUP BY listing_id
) rl ON rl.listing_id = r.listing_id
LEFT JOIN (
    SELECT listing_id, COUNT(*) AS total_reservas_listing
    FROM Calendar
    WHERE available = 0
    GROUP BY listing_id
) c ON c.listing_id = r.listing_id
ORDER BY r.reviewer_id, r.listing_id;


