--Questões Analíticas
--1
SELECT 
    l.neighbourhood,
    l.room_type,
    AVG(l.price) AS preco_medio,
    MIN(l.price) AS preco_minimo,
    MAX(l.price) AS preco_maximo,
    COUNT(*) AS total_casas
FROM Listings l
GROUP BY l.neighbourhood, l.room_type
ORDER BY l.neighbourhood, preco_medio DESC;

--2
SELECT 
    number_of_reviews,
    AVG(price) AS preco_medio,
    COUNT(*) AS total_casas
FROM Listings
GROUP BY number_of_reviews
ORDER BY number_of_reviews;

--3
SELECT
    L.neighbourhood,
    COUNT(DISTINCT L.id) AS total_casas,
    SUM(c.available = 'f') AS dias_reservados
FROM Listings L
JOIN Calendar c
    ON L.id = c.listing_id
GROUP BY L.neighbourhood
ORDER BY total_casas DESC, dias_reservados DESC;

--4
SELECT 
    h.host_id,
    h.host_name,
    h.host_is_superhost,
    COUNT(DISTINCT l.id) AS total_casas,
    COUNT(r.id) AS total_avaliacoes
FROM Hosts h
LEFT JOIN Listings l 
    ON h.host_id = l.host_id
LEFT JOIN Reviews r 
    ON l.id = r.listing_id
GROUP BY h.host_id, h.host_name, h.host_is_superhost
ORDER BY total_casas DESC, total_avaliacoes DESC;

--5
SELECT
    YEAR(c.date) AS ano,
    MONTH(c.date) AS mes,
    l.room_type,
    AVG(c.price) AS preco_medio_diario,
    SUM(CASE WHEN c.available = 1 THEN 1 ELSE 0 END) AS dias_disponiveis,
    SUM(CASE WHEN c.available = 0 THEN 1 ELSE 0 END) AS dias_indisponiveis,
    ROUND(100 * AVG(CASE WHEN c.available = 1 THEN 1 ELSE 0 END), 2) AS taxa_disponibilidade_pct
FROM Calendar c
JOIN Listings l
  ON l.id = c.listing_id
GROUP BY YEAR(c.date), MONTH(c.date), l.room_type
ORDER BY ano, mes, l.room_type;

--6
SELECT 
    MONTH(date) AS mes,
    AVG(price) AS preco_medio,
    COUNT(CASE WHEN available = 0 THEN 1 END) AS noites_reservadas,
    SUM(CASE WHEN available = 0 THEN price ELSE 0 END) AS valor_total_estimado
FROM Calendar
GROUP BY mes
ORDER BY mes;

--7
SELECT 
    l.id AS casa,
    COUNT(DISTINCT r.id) AS total_avaliacoes,
    SUM(CASE WHEN c.available = 0 THEN 1 ELSE 0 END) AS dias_reservados
FROM Listings l
LEFT JOIN Reviews r 
    ON l.id = r.listing_id
LEFT JOIN Calendar c 
    ON l.id = c.listing_id
GROUP BY l.id
ORDER BY dias_reservados DESC;

--8
SELECT 
    l.id AS casa,
    COUNT(DISTINCT r.id) AS total_avaliacoes,
    SUM(CASE WHEN c.available = 0 THEN 1 ELSE 0 END) AS dias_reservados
FROM Listings l
LEFT JOIN Reviews r 
    ON l.id = r.listing_id
LEFT JOIN Calendar c 
    ON l.id = c.listing_id
GROUP BY l.id
ORDER BY dias_reservados DESC;

--9
SELECT 
    YEAR(date) AS ano,
    MONTH(date) AS mes,
    COUNT(CASE WHEN available = 0 THEN 1 END) AS noites_reservadas,
    SUM(CASE WHEN available = 0 THEN price ELSE 0 END) AS pagamento_total_estimado
FROM Calendar
GROUP BY ano, mes
ORDER BY ano, mes;

--10
SELECT 
    r.reviewer_id,
    COUNT(r.id) AS total_avaliacoes,
    l.room_type,
    COUNT(*) AS vezes_reservado
FROM Reviews r
JOIN Listings l 
    ON r.listing_id = l.id
GROUP BY r.reviewer_id, l.room_type
HAVING COUNT(r.id) > 5
ORDER BY total_avaliacoes DESC;

