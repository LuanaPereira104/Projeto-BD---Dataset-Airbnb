USE bd2;

-- Criação da Tabelas
-- Bairros
CREATE TABLE Neighbourhoods (
neighbourhood VARCHAR(255) NOT NULL,
neighbourhood_group VARCHAR(255) NOT NULL,
PRIMARY KEY (neighbourhood)
);

-- Pessoa (Anfitrião)
CREATE TABLE Hosts (
host_id BIGINT NOT NULL,
host_name VARCHAR(255) NOT NULL,
host_since DATE NULL,
host_is_superhost TINYINT(1) NULL, -- 1=t, 0=f
PRIMARY KEY (host_id)
);

-- Casa (Anúncio)
CREATE TABLE Listings (
id BIGINT NOT NULL, -- listing id
host_id BIGINT NOT NULL,
neighbourhood VARCHAR(255) NOT NULL,

latitude DECIMAL(9,6) NULL,
longitude DECIMAL(9,6) NULL,

room_type ENUM('Entire home/apt','Private room','Shared room','Hotel room') NOT NULL,
property_type VARCHAR(255) NOT NULL,

accommodates INT NOT NULL,
price DECIMAL(10,2) NOT NULL,
minimum_nights INT NOT NULL,

number_of_reviews INT NOT NULL DEFAULT 0,
review_scores_rating INT NULL, -- 0..100 ou NULL
availability_365 INT NOT NULL, -- 0..365

PRIMARY KEY (id),

KEY idx_listings_host (host_id),
KEY idx_listings_neighbourhood (neighbourhood),

CONSTRAINT fk_listings_host
FOREIGN KEY (host_id) REFERENCES Hosts(host_id)
ON UPDATE CASCADE
ON DELETE RESTRICT,

CONSTRAINT fk_listings_neighbourhood
FOREIGN KEY (neighbourhood) REFERENCES Neighbourhoods(neighbourhood)
ON UPDATE CASCADE
ON DELETE RESTRICT
);

-- Calendário Diário (por Casa)
CREATE TABLE Calendar (
listing_id BIGINT NOT NULL,
date DATE NOT NULL,
available TINYINT(1) NOT NULL, -- 1=t, 0=f
price DECIMAL(10,2) NOT NULL,

PRIMARY KEY (listing_id, date),
KEY idx_calendar_date (date),

CONSTRAINT fk_calendar_listing
FOREIGN KEY (listing_id) REFERENCES Listings(id)
ON UPDATE CASCADE
ON DELETE CASCADE
);

-- Avaliação
CREATE TABLE Reviews (
id BIGINT NOT NULL, -- review id
listing_id BIGINT NOT NULL,
date DATE NOT NULL,
reviewer_id BIGINT NOT NULL,
reviewer_name VARCHAR(255) NOT NULL,
comments TEXT NULL,

PRIMARY KEY (id),
KEY idx_reviews_listing_date (listing_id, date),

CONSTRAINT fk_reviews_listing
FOREIGN KEY (listing_id) REFERENCES Listings(id)
ON UPDATE CASCADE
ON DELETE CASCADE
);


